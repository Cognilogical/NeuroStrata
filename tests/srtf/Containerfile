# Base image with Node.js and basic tools
FROM ubuntu:24.04

# Avoid tzdata interactive prompts
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    curl \
    ca-certificates \
    git \
    build-essential \
    unzip \
    nodejs \
    npm \
    python3 \
    python3-pip \
    python3-venv \
    pipx \
    ripgrep \
    && rm -rf /var/lib/apt/lists/*

# Copy local opencode binary into the image
COPY opencode /usr/local/bin/opencode
RUN chmod +x /usr/local/bin/opencode

# Set up a generic app user to mimic host user permissions (optional but good practice)
RUN if id "ubuntu" &>/dev/null; then userdel -r ubuntu; fi && useradd -m -u 1000 -s /bin/bash agent

# Switch to agent user
USER agent
WORKDIR /home/agent/workspace

# Install graphifyy for the agent user
RUN pipx install graphifyy
ENV PATH="/home/agent/.local/bin:/usr/local/bin:$PATH"
ENV NEUROSTRATA_DB_PATH="/home/agent/workspace/.neurostrata/db"
ENV OPENCODE_CONFIG="/home/agent/.config/opencode/opencode.json"

# Keep the container alive or run the default command
CMD ["bash"]