{
  "$schema": "https://schema.tauri.app/2.0.0/tauri.schema.json",
  "productName": "NeuroStrata",
  "version": "0.1.1",
  "identifier": "com.cognilogical.neurostrata",
  "build": {
    "beforeDevCommand": "cd ../web-ui && npm run dev",
    "beforeBuildCommand": "cd ../web-ui && npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../web-ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "NeuroStrata Graph",
        "width": 1200,
        "height": 800,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
